---
const insignias = [
  { rank: 'Jonin Prime',    series: '27 nodes',     emblem: '5 Stars',          file: 'Rank1-V12-Jonin-Prime-node-faceplate-1-of-27.png' },
  { rank: 'Jonin Legatus',  series: '148 nodes',    emblem: '4 Stars',          file: 'Rank2-v12-Jonin-Legatus-node-faceplate-1-of-148.png' },
  { rank: 'Jonin Majoris',  series: '240 nodes',    emblem: '2 Stars',          file: 'Rank3-v12-Jonin-Majoris-node-faceplate-1-of-240.png' },
  { rank: 'Chunin Prime',   series: '1,024 nodes',  emblem: 'Eagle',            file: 'Rank4-V12-Chunin-Prime-node-faceplate-1-of-1024.png' },
  { rank: 'Chunin Legatus', series: '2,048 nodes',  emblem: 'Silver Maple Leaf',file: 'Rank5-V12-Chunin-Legatus-node-faceplate-1-of-2048.png' },
  { rank: 'Chunin Majoris', series: '4,096 nodes',  emblem: 'Brass Maple Leaf', file: 'Rank6-V12-Chunin-Majoris-node-faceplate-1-of-4096.png' },
  { rank: 'Genin Maximus',  series: '8,192 nodes',  emblem: 'Two Silver Bars',  file: 'Rank7-V12-Genin-Maximus-node-faceplate-1-of-8192.png' },
  { rank: 'Genin Gladius',  series: '16,384 nodes', emblem: 'Shield & Sword',   file: 'Rank8-V12-Genin-Gladius-node-faceplate-1-of-16384.png' },
  { rank: 'Genin Dýr',      series: '9,841 nodes',  emblem: 'Choice of Weapons',file: 'Rank9-V12-Genin-Dýr-node-faceplate-1-of-9841.png' },
];

const insigniaData = JSON.stringify(insignias.map(({ rank, series, emblem }) => ({ rank, series, emblem })));
---

<div class="not-prose overflow-x-auto">
  <table class="w-full text-sm border-collapse">
    <thead>
      <tr class="border-b-2 border-gray-300 dark:border-gray-600 text-left">
        <th class="py-0 pr-6 font-semibold">Rank</th>
        <th class="py-0 pr-6 font-semibold">Series</th>
        <th class="py-0 pr-6 font-semibold">Emblem</th>
        <th class="py-0 font-semibold">Insignia</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
      {insignias.map(({ rank, series, emblem, file }) => (
        <tr class="py-0 my-0">
          <td class="my-0 py-2 pr-6 font-medium align-middle">{rank}</td>
          <td class="my-0 py-2 pr-6 text-muted align-middle">{series}</td>
          <td class="my-0 py-2 pr-6 text-muted align-middle">{emblem}</td>
          <td class="my-0 py-2 align-middle">
            <img
              src={`/images/insignias/${file}`}
              alt={`${rank} Insignia`}
              class="my-0 py-0 insignia-thumb block h-16 w-auto cursor-pointer rounded hover:opacity-80 transition-opacity"
              data-full={`/images/insignias/${file}`}
            />
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<!-- Lightbox modal -->
<div id="insignia-modal" class="hidden fixed inset-0 bg-black/85 z-[9999] items-center justify-center">
  <button
    id="modal-close"
    aria-label="Close"
    class="absolute top-4 right-6 text-white text-5xl leading-none cursor-pointer bg-transparent border-none p-1 hover:text-gray-300 transition-colors"
  >&times;</button>
  <button
    id="modal-prev"
    aria-label="Previous"
    class="absolute left-4 text-white text-5xl leading-none cursor-pointer bg-transparent border-none p-2 hover:text-gray-300 transition-colors select-none"
  >&#8592;</button>
  <div class="flex flex-col items-center gap-3">
    <img
      id="modal-img"
      src=""
      alt=""
      class="max-w-[90vw] max-h-[80vh] object-contain rounded-lg shadow-2xl"
    />
    <div id="modal-caption" class="text-center text-white">
      <p id="modal-rank" class="text-xl font-semibold"></p>
      <p id="modal-series-emblem" class="text-sm text-gray-300"></p>
    </div>
  </div>
  <button
    id="modal-next"
    aria-label="Next"
    class="absolute right-4 text-white text-5xl leading-none cursor-pointer bg-transparent border-none p-2 hover:text-gray-300 transition-colors select-none"
  >&#8594;</button>
</div>

<script define:vars={{ insigniaData: JSON.parse(insigniaData) }}>
  const modal = document.getElementById('insignia-modal');
  const modalImg = document.getElementById('modal-img');
  const modalClose = document.getElementById('modal-close');
  const modalPrev = document.getElementById('modal-prev');
  const modalNext = document.getElementById('modal-next');
  const modalRank = document.getElementById('modal-rank');
  const modalSeriesEmblem = document.getElementById('modal-series-emblem');
  const thumbs = Array.from(document.querySelectorAll('.insignia-thumb'));
  let currentIndex = 0;

  function showImage(index) {
    currentIndex = (index + thumbs.length) % thumbs.length;
    const thumb = thumbs[currentIndex];
    modalImg.src = thumb.dataset.full ?? thumb.src;
    modalImg.alt = thumb.alt;
    const data = insigniaData[currentIndex];
    if (data) {
      modalRank.textContent = data.rank;
      modalSeriesEmblem.textContent = `${data.series} · ${data.emblem}`;
    }
  }

  thumbs.forEach((img, i) => {
    img.addEventListener('click', () => {
      showImage(i);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  modalClose.addEventListener('click', closeModal);
  modalPrev.addEventListener('click', () => showImage(currentIndex - 1));
  modalNext.addEventListener('click', () => showImage(currentIndex + 1));

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('hidden')) {
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowLeft') showImage(currentIndex - 1);
      if (e.key === 'ArrowRight') showImage(currentIndex + 1);
    }
  });
</script>
