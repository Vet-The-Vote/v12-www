---
import { SITE } from 'astrowind:config';
---

<span class="self-center ml-2 rtl:ml-0 rtl:mr-2 flex items-center gap-2 whitespace-nowrap">
  <img
    src="/images/logo/logo_color_background_transparent_192x192.png"
    alt="Vet The Vote (V12) Logo"
    class="h-8 w-8 object-contain"
  />
  <span class="text-2xl md:text-xl font-bold text-gray-900 dark:text-white">
    {SITE?.name}
  </span>
</span>
